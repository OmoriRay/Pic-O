<Window x:Class="Pixora.BatchDeletePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量删除确认"
        Width="560"
        Height="360"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="#101216"
        Foreground="#F2F5F7"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#171A20"
                BorderBrush="#2F3B48"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <StackPanel>
                <TextBlock Text="确认批量删除媒体文件"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#F2F5F7" />
                <TextBlock x:Name="SummaryText"
                           Margin="0,12,0,0"
                           Foreground="#DCE4EC"
                           FontSize="13"
                           LineHeight="21"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="FolderText"
                           Margin="0,12,0,0"
                           Foreground="#AEB8C4"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <CheckBox x:Name="IncludeSubfoldersCheckBox"
                          Content="同时删除子目录下的媒体文件"
                          Margin="0,18,0,0"
                          Foreground="#DCE4EC" />
                <TextBlock Text="只会删除支持的图片、动图和视频文件，并移入回收站；不会删除文件夹或其它类型文件。"
                           Margin="26,8,0,0"
                           Foreground="#AEB8C4"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Content="取消"
                    MinWidth="92"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Grid.Column="2"
                    Content="删除到回收站"
                    MinWidth="122"
                    Padding="14,8"
                    IsDefault="True"
                    Click="DeleteButton_Click" />
        </Grid>
    </Grid>
</Window>
